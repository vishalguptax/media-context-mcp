{
  "name": "media-context-mcp",
  "version": "0.1.0",
  "description": "100% local, zero-API MCP server that turns a video, audio, or image file/URL into low-token context for AI agents — montage frames, scene detection, speech transcript (Whisper), and on-screen OCR (Tesseract). No cloud upload, no keys.",
  "type": "module",
  "author": "Vishal Gupta (https://github.com/vishalguptax)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalguptax/media-context-mcp.git"
  },
  "homepage": "https://github.com/vishalguptax/media-context-mcp#readme",
  "bugs": {
    "url": "https://github.com/vishalguptax/media-context-mcp/issues"
  },
  "bin": {
    "media-context-mcp": "dist/index.js"
  },
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video",
    "audio",
    "image",
    "ocr",
    "tesseract",
    "ffmpeg",
    "yt-dlp",
    "whisper",
    "transcript",
    "screen-recording",
    "local",
    "claude",
    "ai",
    "frames"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
